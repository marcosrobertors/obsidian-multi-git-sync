{
  "name": "obsidian-multi-git-sync",
  "version": "0.1.5",
  "description": "Obsidian plugin for syncing multiple vault scopes to Git remotes.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "typecheck": "tsc -noEmit -skipLibCheck",
    "package": "npm run build && node scripts/package.mjs"
  },
  "keywords": [
    "obsidian",
    "git",
    "sync",
    "github"
  ],
  "author": "Marcos",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.30",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.20.2",
    "obsidian": "^1.5.12",
    "typescript": "^5.4.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marcosrobertors/multi-git-sync.git"
  },
  "bugs": {
    "url": "https://github.com/marcosrobertors/multi-git-sync/issues"
  },
  "homepage": "https://github.com/marcosrobertors/multi-git-sync#readme"
}
